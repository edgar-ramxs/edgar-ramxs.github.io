---
import Layout from "@layouts/PortfolioLayout.astro";
import { certificationsData, skillsData } from "@cv";
import { Icon } from "astro-icon/components";
const { certifications, skills } = { certifications: certificationsData, skills: skillsData };

// Mapeo de iconos para skills
const skillIcons = Object.fromEntries(skills.Technicals.map((s) => [s.name, s.icon]));

export async function getStaticPaths() {
  const { certifications } = (await import("@cv")).default;
  return certifications.map((cert) => ({
    params: { id: cert.id },
    props: { cert },
  }));
}

const { cert } = Astro.props;
---

<Layout title={cert.name} description={cert.description} keywords={cert.skills}>
  <article class="section fade-up">
    <div class="container">
      <div class="certification-detail-header">
        <a href="/certifications" class="back-link">← Volver a Certificaciones</a>
        <div class="header-main">
          <div class="header-left">
            <h1 class="cert-full-title">{cert.name}</h1>
            <p class="cert-issuer-full">{cert.issuer}</p>
          </div>
          <div class="header-right">
            <div class="cert-icon-container-large">
              <Icon name={cert.icon} class="cert-icon-large-img" />
            </div>
          </div>
        </div>
      </div>

      <div class="certification-content-grid">
        <div class="main-content">
          <section class="cert-block">
            <h2 class="block-title">Descripción</h2>
            <p class="cert-desc-text">{cert.description}</p>
          </section>

          {
            cert.url && (
              <div class="cert-actions">
                <a
                  href={cert.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary"
                >
                  Verificar Credencial
                  <Icon name="ph:arrow-up-right" width="18" height="18" />
                </a>
              </div>
            )
          }
        </div>

        <aside class="cert-sidebar">
          <div class="sidebar-block">
            <h3 class="sidebar-title">Fecha de Emisión</h3>
            <p class="sidebar-info">
              {
                new Date(cert.date).toLocaleDateString("es-ES", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              }
            </p>
          </div>

          <div class="sidebar-block">
            <h3 class="sidebar-title">Competencias Validadas</h3>
            <div class="skills-cloud">
              {
                cert.skills.map((skill) => (
                  <span class="skill-pill">
                    {skillIcons[skill] && <Icon name={skillIcons[skill]} class="pill-icon" />}
                    {skill}
                  </span>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .certification-detail-header {
    margin-bottom: 5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 3rem;
  }

  .back-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 2.5rem;
    display: inline-block;
  }

  .header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
  }

  .cert-full-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.15;
    font-weight: 400;
    margin-bottom: 1rem;
    max-width: 800px;
  }

  .cert-issuer-full {
    font-family: var(--mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    font-weight: 500;
  }

  .cert-icon-container-large {
    width: 6rem;
    height: 6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(10deg);
  }

  .cert-icon-large-img {
    width: 3.5rem;
    height: 3.5rem;
    color: var(--text);
    opacity: 0.3;
  }

  .certification-content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 5rem;
  }

  .cert-block {
    margin-bottom: 4rem;
  }

  .block-title {
    font-family: var(--serif);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 2rem;
  }

  .cert-desc-text {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 750px;
  }

  .cert-actions {
    margin-top: 5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--text);
    transform: translateY(-2px);
  }

  .sidebar-block {
    margin-bottom: 3.5rem;
  }

  .sidebar-title {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .sidebar-info {
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 500;
  }

  .skills-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    background: var(--surface);
    color: var(--text-muted);
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  .pill-icon {
    width: 0.9rem;
    height: 0.9rem;
  }

  @media (max-width: 900px) {
    .certification-content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .header-main {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .cert-icon-large {
      display: none;
    }
  }
</style>
