---
import Layout from "@layouts/PortfolioLayout.astro";
import { getSkillById } from "@cv";
import { Icon } from "astro-icon/components";
import { marked } from "marked";
import matter from "gray-matter";
import { readFile } from "fs/promises";
import { join } from "path";

export async function getStaticPaths() {
  const projectsDir = join(process.cwd(), "src/data/projects");
  const { readdir } = await import("fs/promises");
  const files = await readdir(projectsDir);

  const results = await Promise.all(
    files
      .filter((f) => f.endsWith(".md"))
      .map(async (fileName) => {
        const filePath = join(projectsDir, fileName);
        const raw = await readFile(filePath, "utf-8");
        const { data, content } = matter(raw);
        return {
          params: { id: data.id },
          props: { ...data, rawContent: content },
        };
      })
  );

  return results;
}

const { id, name, github, url, isActive, stack, highlights, description, rawContent } = Astro.props;

let readmeContent = "";
const hasLocalContent = rawContent && rawContent.trim().length > 0;

if (github) {
  try {
    const match = github.match(/github\.com\/([^/]+)\/([^/]+)/);
    if (match) {
      const [, owner, repo] = match;
      const readmeUrl = `https://raw.githubusercontent.com/${owner}/${repo}/main/README.md`;
      const response = await fetch(readmeUrl);
      if (response.ok) {
        const markdown = await response.text();
        readmeContent = await marked(markdown);
      }
    }
  } catch (e) {
    console.log("Could not fetch README for", id);
  }
}

const displayContent = hasLocalContent ? await marked(rawContent) : readmeContent;
const projectDescription = description || (hasLocalContent ? "" : "Proyecto sin descripción");
---

<Layout title={name} description={projectDescription} keywords={stack}>
  <article class="section fade-up">
    <div class="container">
      <div class="project-detail-header">
        <a href="/projects" class="back-link">← Volver a Proyectos</a>
        <div class="header-main">
          <h1 class="project-full-title">{name}</h1>
          <div class="project-badge">
            {isActive ? "Proyecto Activo" : "Proyecto Finalizado"}
          </div>
        </div>
        {projectDescription && <p class="project-full-desc">{projectDescription}</p>}
      </div>

      <div class="project-detail-grid">
        <div class="project-main-content">
          {
            displayContent && (
              <section class="detail-section readme-section">
                <h2 class="detail-title">README</h2>
                <div class="readme-content" set:html={displayContent} />
              </section>
            )
          }

          {
            highlights && highlights.length > 0 && (
              <section class="detail-section">
                <h2 class="detail-title">Características Destacadas</h2>
                <ul class="highlights-list">
                  {highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </section>
            )
          }

          <div class="project-actions">
            {
              url && (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary"
                  data-project-id={id}
                  data-project-name={name}
                  data-project-action="visit"
                >
                  Visitar Sitio Web
                  <Icon name="ph:arrow-up-right" width="18" height="18" />
                </a>
              )
            }
            {
              github && (
                <a
                  href={github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-secondary"
                  data-project-id={id}
                  data-project-name={name}
                  data-project-action="github"
                >
                  Ver Código Fuente
                  <Icon name="mdi:github" width="18" height="18" />
                </a>
              )
            }
          </div>
        </div>

        <aside class="project-sidebar">
          <div class="sidebar-block">
            <h3 class="sidebar-title">Tecnologías</h3>
            <div class="tech-cloud">
              {
                stack &&
                  stack.map((techId) => {
                    const skill = getSkillById(techId);
                    return (
                      <span class="tag tag-default">
                        {skill?.icon && <Icon name={skill.icon} class="tag-icon" />}
                        {skill?.name || techId}
                      </span>
                    );
                  })
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .project-detail-header {
    margin-bottom: 5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 3rem;
  }

  .back-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 2.5rem;
    display: inline-block;
  }

  .header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    gap: 2rem;
  }

  .project-full-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    font-weight: 400;
    margin: 0;
  }

  .project-badge {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
  }

  .project-full-desc {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 800px;
    line-height: 1.6;
  }

  .project-detail-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 5rem;
  }

  .detail-section {
    margin-bottom: 4rem;
  }

  .detail-title {
    font-family: var(--serif);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 2rem;
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .highlights-list li {
    font-size: 1.05rem;
    padding-left: 2rem;
    position: relative;
    line-height: 1.6;
    color: var(--text);
  }

  .highlights-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--mono);
  }

  .project-actions {
    display: flex;
    gap: 1.5rem;
    margin-top: 5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--text);
    transform: translateY(-2px);
  }

  .btn-secondary {
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .sidebar-block {
    margin-bottom: 3rem;
  }

  .sidebar-title {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .tech-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: none;
    background: var(--surface);
    color: var(--text-muted);
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  .tag-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  .readme-section {
    margin-bottom: 4rem;
  }

  .readme-content {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text);
  }

  .readme-content :global(h1),
  .readme-content :global(h2),
  .readme-content :global(h3) {
    font-family: var(--serif);
    font-weight: 400;
    margin: 1.5em 0 0.5em;
  }

  .readme-content :global(h1) {
    font-size: 1.75rem;
  }
  .readme-content :global(h2) {
    font-size: 1.5rem;
  }
  .readme-content :global(h3) {
    font-size: 1.25rem;
  }

  .readme-content :global(p) {
    margin-bottom: 1em;
  }

  .readme-content :global(code) {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--surface);
    padding: 0.2em 0.4em;
    border-radius: 2px;
  }

  .readme-content :global(pre) {
    background: var(--surface);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 1em 0;
  }

  .readme-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .readme-content :global(ul),
  .readme-content :global(ol) {
    margin: 1em 0;
    padding-left: 1.5em;
  }

  .readme-content :global(li) {
    margin-bottom: 0.5em;
  }

  .readme-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }

  .readme-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1em 0;
    padding-left: 1rem;
    color: var(--text-muted);
  }

  <script>
  // Track project view on page load
  const projectId = document.querySelector('[data-project-id]')?.dataset.projectId;
  const projectName = document.querySelector('[data-project-name]')?.dataset.projectName;

  if (projectId && window.dataLayer) {
    window.dataLayer.push({
      event: 'project_view',
      project: {
        id: projectId,
        name: projectName
      }
    });
  }

  // Track project action clicks
  document.querySelectorAll('[data-project-action]').forEach(link => {
    link.addEventListener('click', () => {
      const action = link.dataset.projectAction;
      
      if (window.dataLayer) {
        window.dataLayer.push({
          event: 'project_action',
          project: {
            id: projectId,
            name: projectName,
            action: action
          }
        });
      }
      
      if (window.gtag) {
        window.gtag('event', 'project_action', {
          project_id: projectId,
          project_name: projectName,
          action: action
        });
      }
    });
  });
</script>

  @media (max-width: 1000px) {
    .project-detail-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .header-main {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .project-full-title {
      font-size: 3rem;
    }
  }
</style>
