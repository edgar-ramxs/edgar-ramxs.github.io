---
import Layout from "@layouts/PortfolioLayout.astro";
import { projectsData, skillsData } from "@cv";
import { Icon } from "astro-icon/components";
const { projects, skills } = { projects: projectsData, skills: skillsData };

// Mapeo de iconos para skills
const skillIcons = Object.fromEntries(skills.Technicals.map((s) => [s.name, s.icon]));

export async function getStaticPaths() {
  const { projects } = (await import("@cv")).default;
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={project.name} description={project.description} keywords={project.stack}>
  <article class="section fade-up">
    <div class="container">
      <div class="project-detail-header">
        <a href="/projects" class="back-link">← Volver a Proyectos</a>
        <div class="header-main">
          <h1 class="project-full-title">{project.name}</h1>
          <div class="project-badge">
            {project.isActive ? "Proyecto Activo" : "Proyecto Finalizado"}
          </div>
        </div>
        <p class="project-full-desc">{project.description}</p>
      </div>

      <div class="project-detail-grid">
        <div class="project-main-content">
          {
            project.highlights && project.highlights.length > 0 && (
              <section class="detail-section">
                <h2 class="detail-title">Características Destacadas</h2>
                <ul class="highlights-list">
                  {project.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </section>
            )
          }

          <div class="project-actions">
            {
              project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-primary"
                >
                  Visitar Sitio Web
                  <Icon name="ph:arrow-up-right" width="18" height="18" />
                </a>
              )
            }
            {
              project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-secondary"
                >
                  Ver Código Fuente
                  <Icon name="mdi:github" width="18" height="18" />
                </a>
              )
            }
          </div>
        </div>

        <aside class="project-sidebar">
          <div class="sidebar-block">
            <h3 class="sidebar-title">Tecnologías</h3>
            <div class="tech-cloud">
              {
                project.stack.map((tech) => (
                  <span class="tech-pill">
                    {skillIcons[tech] && <Icon name={skillIcons[tech]} class="pill-icon" />}
                    {tech}
                  </span>
                ))
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .project-detail-header {
    margin-bottom: 5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 3rem;
  }

  .back-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 2.5rem;
    display: inline-block;
  }

  .header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    gap: 2rem;
  }

  .project-full-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    font-weight: 400;
    margin: 0;
  }

  .project-badge {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
  }

  .project-full-desc {
    font-size: 1.2rem;
    color: var(--text-muted);
    max-width: 800px;
    line-height: 1.6;
  }

  .project-detail-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 5rem;
  }

  .detail-section {
    margin-bottom: 4rem;
  }

  .detail-title {
    font-family: var(--serif);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 2rem;
  }

  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .highlights-list li {
    font-size: 1.05rem;
    padding-left: 2rem;
    position: relative;
    line-height: 1.6;
    color: var(--text);
  }

  .highlights-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-family: var(--mono);
  }

  .project-actions {
    display: flex;
    gap: 1.5rem;
    margin-top: 5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--text);
    transform: translateY(-2px);
  }

  .btn-secondary {
    border: 1px solid var(--border);
    color: var(--text);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .sidebar-block {
    margin-bottom: 3rem;
  }

  .sidebar-title {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .tech-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    background: var(--surface);
    color: var(--text-muted);
    padding: 0.3rem 0.7rem;
    border-radius: 2px;
  }

  .pill-icon {
    width: 0.9rem;
    height: 0.9rem;
  }

  @media (max-width: 1000px) {
    .project-detail-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .header-main {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .project-full-title {
      font-size: 3rem;
    }
  }
</style>
