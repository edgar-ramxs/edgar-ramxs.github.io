---
import Layout from "@layouts/PortfolioLayout.astro";
import { Icon } from "astro-icon/components";

import { skillsData } from "@cv";
const { Softs, Technicals } = skillsData;

// Categorización de habilidades técnicas por "Tarea" o "Ámbito"
const technicalCategories = [
  {
    title: "Desarrollo Frontend",
    description: "Creación de interfaces de usuario modernas, responsivas y performantes.",
    skills: Technicals.filter(
      (s) =>
        s.keywords.includes("Frontend") ||
        ["React", "Next-Js", "Astro", "Tailwind", "HTML", "CSS", "MUI"].includes(s.name)
    ),
  },
  {
    title: "Backend & APIs",
    description: "Construcción de lógica de servidor, APIs RESTful y sistemas robustos.",
    skills: Technicals.filter(
      (s) =>
        s.keywords.includes("Backend") ||
        ["Go-lang", "Gin", "Node", "Java", "Swagger", "Postman", "Bruno"].includes(s.name)
    ),
  },
  {
    title: "Bases de Datos",
    description: "Gestión de datos relacionales y NoSQL para aplicaciones escalables.",
    skills: Technicals.filter(
      (s) => s.keywords.includes("Databases") || ["PostgreSQL", "MongoDB"].includes(s.name)
    ),
  },
  {
    title: "Herramientas & DevOps",
    description: "Control de versiones, despliegue en la nube y automatización.",
    skills: Technicals.filter(
      (s) =>
        s.keywords.includes("Version Control") ||
        s.keywords.includes("Cloud Computing") ||
        s.keywords.includes("Automation") ||
        ["Docker", "Linux", "Git", "GitHub", "AWS", "PNPM"].includes(s.name)
    ),
  },
  {
    title: "Validación & Estado",
    description: "Gestión de estado complejo, validación de esquemas y fetching de datos.",
    skills: Technicals.filter((s) => ["Zod", "React Query", "React Hook Form"].includes(s.name)),
  },
];
---

<Layout
  title="Habilidades"
  description="Mis habilidades profesionales y stack tecnológico clasificado por ámbitos de aplicación."
>
  <section class="section fade-up">
    <div class="container">
      <p class="section-label">Capacidades</p>
      <h2 class="section-title">Habilidades & Stack</h2>

      {/* --- SOFT SKILLS FIRST --- */}
      <div class="skills-section">
        <div class="skills-header">
          <h3 class="skills-type-title">Habilidades Profesionales (Soft Skills)</h3>
          <p class="skills-type-desc">
            Fundamentos que me permiten trabajar eficazmente en equipos y resolver problemas
            complejos.
          </p>
        </div>
        <div class="soft-skills-grid">
          {
            Softs.map((skill) => (
              <div class="soft-skill-card">
                <Icon name="ph:star-four-fill" class="soft-skill-icon" />
                <span class="soft-skill-name">{skill}</span>
              </div>
            ))
          }
        </div>
      </div>

      {/* --- TECHNICAL SKILLS BY TASK --- */}
      <div class="skills-section">
        <div class="skills-header">
          <h3 class="skills-type-title">Stack Técnico por Ámbitos</h3>
          <p class="skills-type-desc">
            Clasificación de mis herramientas técnicas según la tarea y el valor que aportan al
            proyecto.
          </p>
        </div>

        <div class="tech-categories-container">
          {
            technicalCategories.map((category) => (
              <div class="tech-category-block">
                <div class="category-info">
                  <h4 class="category-title">{category.title}</h4>
                  <p class="category-desc">{category.description}</p>
                </div>
                <div class="category-skills">
                  {category.skills.map((skill) => (
                    <div class="tech-pill" title={`Nivel: ${skill.level}`}>
                      <Icon name={skill.icon} class="tech-icon" />
                      <span class="tech-name">{skill.name}</span>
                      <span class={`level-indicator ${skill.level.toLowerCase()}`} />
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .skills-section {
    margin-bottom: 6rem;
  }

  .skills-header {
    margin-bottom: 3rem;
    max-width: 600px;
  }

  .skills-type-title {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .skills-type-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Soft Skills Styles */
  .soft-skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .soft-skill-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .soft-skill-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .soft-skill-icon {
    width: 1rem;
    height: 1rem;
    color: var(--accent);
  }

  .soft-skill-name {
    font-family: var(--mono);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--text);
  }

  /* Technical Categories Styles */
  .tech-categories-container {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--border);
  }

  .tech-category-block {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
  }

  .category-title {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .category-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .category-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-content: flex-start;
  }

  .tech-pill {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  .tech-pill:hover {
    border-color: var(--accent);
    background: var(--surface);
  }

  .tech-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--text);
  }

  .tech-pill:hover .tech-icon {
    color: var(--accent);
  }

  .tech-name {
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
  }

  .level-indicator {
    width: 4px;
    height: 4px;
    border-radius: 50%;
  }

  .level-indicator.advanced {
    background: #10b981;
    box-shadow: 0 0 8px #10b98166;
  }
  .level-indicator.intermediate {
    background: #f59e0b;
  }
  .level-indicator.beginner {
    background: #6b7280;
  }

  @media (max-width: 850px) {
    .tech-category-block {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2.5rem 0;
    }
  }
</style>
