---
import Layout from "@layouts/PortfolioLayout.astro";
import { worksData, skillsData } from "@cv";
import { Icon } from "astro-icon/components";
const { works, skills } = { works: worksData, skills: skillsData };

// Mapeo de iconos para skills
const skillIcons = Object.fromEntries(skills.Technicals.map((s) => [s.name, s.icon]));

const formatDate = (dateStr: string | null) => {
  if (!dateStr) return "Presente";
  return new Date(dateStr).toLocaleDateString("es-ES", { year: "numeric", month: "short" });
};
---

<Layout
  title="Experiencia"
  description="Mi experiencia laboral profesional"
  keywords={["trabajo", "empleo", "desarrollo", "frontend", "fullstack"]}
>
  <section class="section fade-up">
    <div class="container">
      <p class="section-label">Historial</p>
      <h2 class="section-title">Experiencia Detallada</h2>

      <div class="timeline-container">
        {
          works.map((exp) => (
            <a href={`/experiences/${exp.id}`} class="timeline-item group">
              <div class="timeline-meta">
                <div class="timeline-icon-wrapper">
                  <Icon name={exp.icon} class="timeline-icon" />
                </div>
                <span class="timeline-period">
                  {formatDate(exp.startDate)} — {formatDate(exp.endDate)}
                </span>
                <span class="timeline-location">
                  {exp.location} ({exp.location_type})
                </span>
              </div>

              <div class="timeline-content">
                <h3 class="role-title">{exp.position}</h3>
                <p class="company-name">{exp.name}</p>
                <p class="role-summary">{exp.summary}</p>
                <div class="role-tags">
                  {exp.skills.slice(0, 5).map((skill) => (
                    <span class="skill-tag">
                      {skillIcons[skill] && <Icon name={skillIcons[skill]} class="tag-icon" />}
                      {skill}
                    </span>
                  ))}
                  {exp.skills.length > 5 && (
                    <span class="skill-tag-plus">+{exp.skills.length - 5}</span>
                  )}
                </div>
              </div>

              <div class="timeline-action">
                <span class="view-details">Ver detalles →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .timeline-container {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--border);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 240px 1fr 180px;
    gap: 3rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .timeline-item:hover {
    padding-left: 2rem;
    background: var(--surface);
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .timeline-icon-wrapper {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--accent-soft);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
    transition: transform 0.3s ease;
  }

  .timeline-item:hover .timeline-icon-wrapper {
    transform: scale(1.1);
    border-color: var(--accent);
  }

  .timeline-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--accent);
  }

  .timeline-period {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .timeline-location {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .timeline-content {
    max-width: 650px;
  }

  .role-title {
    font-family: var(--serif);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 0.4rem;
    transition: color 0.3s ease;
  }

  .timeline-item:hover .role-title {
    color: var(--accent);
  }

  .company-name {
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text);
    margin-bottom: 1.2rem;
    font-weight: 500;
  }

  .role-summary {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .role-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tag {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  .tag-icon {
    width: 0.8rem;
    height: 0.8rem;
  }

  .skill-tag-plus {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--text-muted);
    padding: 0.2rem 0.6rem;
  }

  .timeline-action {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding-top: 0.5rem;
  }

  .view-details {
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .timeline-item:hover .view-details {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2.5rem 0;
    }
    .timeline-action {
      justify-content: flex-start;
    }
    .view-details {
      opacity: 1;
    }
  }
</style>
