---
import Layout from "@layouts/PortfolioLayout.astro";
import { worksData, getSkillById } from "@cv";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
  return worksData.map((exp) => ({
    params: { id: exp.id },
    props: { exp },
  }));
}

const { exp } = Astro.props;

const formatDate = (dateStr: string | null) => {
  if (!dateStr) return "Presente";
  return new Date(dateStr).toLocaleDateString("es-ES", {
    year: "numeric",
    month: "long",
  });
};
---

<Layout title={`${exp.position} en ${exp.name}`} description={exp.summary} keywords={exp.skills}>
  <article class="section fade-up">
    <div class="container">
      <div class="experience-detail-header">
        <a href="/experiences" class="back-link">← Volver a Experiencia</a>
        <div class="header-main">
          <div class="header-left" data-exp-id={exp.id} data-exp-name={exp.position}>
            <div class="role-icon-container">
              <Icon name={exp.icon} class="role-icon" />
            </div>
            <h1 class="role-title">{exp.position}</h1>
            <p class="company-name">{exp.name}</p>
          </div>
          <div class="header-right">
            <div class="period-badge">
              {formatDate(exp.startDate)} — {formatDate(exp.endDate)}
            </div>
          </div>
        </div>
      </div>

      <div class="experience-content-grid">
        <div class="main-content">
          <section class="experience-block">
            <h2 class="block-title">Sobre el Rol</h2>
            <p class="role-desc">{exp.summary}</p>
          </section>

          <section class="experience-block">
            <h2 class="block-title">Responsabilidades Clave</h2>
            <ul class="responsibilities-list">
              {exp.responsibilities.map((resp) => <li>{resp}</li>)}
            </ul>
          </section>

          {
            exp.url && (
              <div class="experience-actions">
                <a href={exp.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                  Sitio Web de la Empresa
                  <Icon name="ph:arrow-up-right" width="18" height="18" />
                </a>
              </div>
            )
          }
        </div>

        <aside class="experience-sidebar">
          <div class="sidebar-block">
            <h3 class="sidebar-title">Ubicación</h3>
            <p class="sidebar-info">{exp.location} ({exp.location_type})</p>
          </div>

          <div class="sidebar-block">
            <h3 class="sidebar-title">Tecnologías & Skills</h3>
            <div class="skills-cloud">
              {
                exp.skills.map((skillId) => {
                  const skill = getSkillById(skillId);
                  return (
                    <span class="tag tag-default">
                      {skill?.icon && <Icon name={skill.icon} class="tag-icon" />}
                      {skill?.name || skillId}
                    </span>
                  );
                })
              }
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .experience-detail-header {
    margin-bottom: 5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 3rem;
  }

  .back-link {
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 2.5rem;
    display: inline-block;
  }

  .header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
  }

  .role-icon-container {
    width: 3.5rem;
    height: 3.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .role-icon {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--accent);
  }

  .role-title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.1;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .company-name {
    font-family: var(--mono);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    font-weight: 500;
  }

  .period-badge {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    margin-bottom: 0.5rem;
  }

  .experience-content-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 5rem;
  }

  .experience-block {
    margin-bottom: 4rem;
  }

  .block-title {
    font-family: var(--serif);
    font-size: 1.75rem;
    font-weight: 400;
    margin-bottom: 2rem;
  }

  .role-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 750px;
  }

  .responsibilities-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .responsibilities-list li {
    font-size: 1.05rem;
    padding-left: 2rem;
    position: relative;
    line-height: 1.6;
    color: var(--text);
  }

  .responsibilities-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 1.5rem;
    line-height: 1;
    top: -0.1rem;
  }

  .experience-actions {
    margin-top: 5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--text);
    transform: translateY(-2px);
  }

  .sidebar-block {
    margin-bottom: 3.5rem;
  }

  .sidebar-title {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .sidebar-info {
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 500;
  }

  .skills-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    text-transform: none;
    background: var(--surface);
    color: var(--text-muted);
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  .tag-icon {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  <script>
  // Track experience view on page load
  const expId = document.querySelector('[data-exp-id]')?.dataset.expId;
  const expName = document.querySelector('[data-exp-name]')?.dataset.expName;

  if (expId && window.dataLayer) {
    window.dataLayer.push({
      event: 'experience_view',
      experience: {
        id: expId,
        name: expName
      }
    });
  }

  // Track experience action clicks
  document.querySelectorAll('[data-exp-action]').forEach(link => {
    link.addEventListener('click', () => {
      const action = link.dataset.expAction;
      
      if (window.dataLayer) {
        window.dataLayer.push({
          event: 'experience_action',
          experience: {
            id: expId,
            name: expName,
            action: action
          }
        });
      }
      
      if (window.gtag) {
        window.gtag('event', 'experience_action', {
          experience_id: expId,
          experience_name: expName,
          action: action
        });
      }
    });
  });
</script>

  @media (max-width: 1000px) {
    .experience-content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .header-main {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }
</style>
