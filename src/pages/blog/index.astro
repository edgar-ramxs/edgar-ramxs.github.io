---
import Layout from '@layouts/ProjectLayout.astro';
import BlogHeader from '@components/blog/BlogHeader.astro';
import BlogFooter from '@components/blog/BlogFooter.astro';
import type { MarkdownInstance } from 'astro';

interface BlogPost {
  title: string;
  author: string;
  date: string;
  categories: string[];
  description: string;
  image: string;
  readTime: string;
}

type BlogModule = MarkdownInstance<BlogPost>;

const modules = import.meta.glob('/data/blogs/*.md', { eager: true }) as Record<string, BlogModule>;
const allPosts = Object.entries(modules).map(([path, post]) => {
  const slug = path.split("/").pop()?.replace(".md", "") ?? "";
  return {
    slug,
    frontmatter: post.frontmatter,
  };
}).sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const featuredPost = allPosts[0];
const latestPosts = allPosts.slice(1, 4);

const categories = [
  { name: "Motion Craft", icon: "auto_awesome", color: "#6dddff" },
  { name: "Spatial UI", icon: "architecture", color: "#bf81ff" },
  { name: "Design Theory", icon: "history_edu", color: "#78ef9a" },
  { name: "Code & Form", icon: "terminal", color: "#ff716c" },
  { name: "Curation", icon: "collections", color: "#00d2fd" },
];
---

<Layout
  title="Blog · The Kinetic Journal"
  description="Deep dives into digital craft and kinetic design."
>
  <BlogHeader />

  <main class="journal-main">
    <!-- Page Title Section -->
    <section class="journal-hero">
      <h1 class="journal-title">The Kinetic Journal</h1>
      <p class="journal-subtitle">
        Deep dives into digital craft and kinetic design.
      </p>
    </section>

    <!-- Featured Post -->
    <section class="journal-featured">
      {featuredPost && (
        <div class="featured-card">
          <img 
            class="featured-image"
            src={featuredPost.frontmatter.image || '/assets/images/astro-vim.webp'} 
            alt={featuredPost.frontmatter.title}
          />
          <div class="featured-overlay"></div>
          <div class="featured-content">
            <span class="featured-badge">Featured Insight</span>
            <h2 class="featured-title">{featuredPost.frontmatter.title}</h2>
            <p class="featured-excerpt">{featuredPost.frontmatter.description}</p>
            <a href={`/blog/posts/${featuredPost.slug}`} class="featured-btn">
              Read More
              <span class="material-symbols-outlined">arrow_right_alt</span>
            </a>
          </div>
        </div>
      )}
    </section>

    <!-- Latest Insights -->
    <section class="journal-latest">
      <div class="latest-header">
        <h3 class="latest-title">Latest Insights</h3>
        <a href="/blog/posts" class="latest-link">View Archive</a>
      </div>
      <div class="latest-grid">
        {latestPosts.map((post) => (
          <article class="latest-card">
            <div class="latest-card-image">
              <img 
                src={post.frontmatter.image || '/assets/images/astro-vim.webp'} 
                alt={post.frontmatter.title}
              />
              <span class="latest-card-category">{post.frontmatter.categories?.[0]}</span>
            </div>
            <div class="latest-card-content">
              <h4 class="latest-card-title">
                <a href={`/blog/posts/${post.slug}`}>{post.frontmatter.title}</a>
              </h4>
              <p class="latest-card-excerpt">{post.frontmatter.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Popular Categories -->
    <section class="journal-categories">
      <h3 class="categories-title">Popular Categories</h3>
      <div class="categories-grid">
        {categories.map((cat) => (
          <button class="category-btn" style={`--cat-color: ${cat.color}`}>
            <span class="material-symbols-outlined">{cat.icon}</span>
            <span>{cat.name}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Newsletter -->
    <section class="journal-newsletter">
      <div class="newsletter-card">
        <div class="newsletter-blob-1"></div>
        <div class="newsletter-blob-2"></div>
        <div class="newsletter-content">
          <h3 class="newsletter-title">Stay Curated</h3>
          <p class="newsletter-desc">
            Get bi-weekly insights on the intersection of motion, craft, and digital engineering delivered straight to your inbox.
          </p>
          <form class="newsletter-form">
            <input 
              type="email" 
              placeholder="Your creative email" 
              class="newsletter-input"
            />
            <button type="submit" class="newsletter-btn">
              Subscribe
            </button>
          </form>
          <p class="newsletter-note">No noise. Just high-fidelity craft.</p>
        </div>
      </div>
    </section>
  </main>

  <BlogFooter />

  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --surface-dim: #05070a;
      --surface: #0c0e12;
      --surface-container-high: #1a1e26;
      --surface-container-low: #080a0f;
      --surface-bright: #1a1e26;
      --on-surface: #f8f9fe;
      --on-surface-variant: #adaaaa;
      --primary: #00d2ff;
      --primary-container: #00d2fd;
      --secondary: #bf81ff;
      --tertiary: #78ef9a;
      --error: #ff716c;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    body {
      background-color: var(--surface-dim);
      color: var(--on-surface);
      font-family: 'Inter', sans-serif;
    }

    body ::selection {
      background: rgba(0, 210, 255, 0.3);
      color: var(--primary);
    }
  </style>

  <style>
    .journal-main {
      padding: 8rem 1.5rem 4rem;
      max-width: 1400px;
      margin: 0 auto;
      position: relative;
    }

    @media (min-width: 768px) {
      .journal-main {
        padding: 8rem 6rem 4rem;
      }
    }

    /* Hero */
    .journal-hero {
      padding: 4rem 0;
      margin-bottom: 2rem;
    }

    .journal-title {
      font-family: "Manrope", sans-serif;
      font-size: clamp(3rem, 8vw, 5rem);
      font-weight: 900;
      letter-spacing: -0.04em;
      margin: 0 0 1rem 0;
      color: var(--on-surface);
    }

    .journal-subtitle {
      font-family: "Inter", sans-serif;
      font-size: 1.25rem;
      color: var(--on-surface-variant);
      max-width: 40ch;
      margin: 0;
    }

    /* Featured */
    .journal-featured {
      margin-bottom: 8rem;
    }

    .featured-card {
      position: relative;
      height: 600px;
      border-radius: 12px;
      overflow: hidden;
    }

    .featured-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.6;
      transition: transform 0.7s ease;
    }

    .featured-card:hover .featured-image {
      transform: scale(1.05);
    }

    .featured-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, var(--surface) 0%, rgba(12, 14, 18, 0.4) 100%);
    }

    .featured-content {
      position: relative;
      z-index: 10;
      padding: 4rem;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }

    .featured-badge {
      display: inline-block;
      background: rgba(0, 210, 255, 0.1);
      border: 1px solid rgba(0, 210, 255, 0.2);
      color: var(--primary);
      padding: 0.25rem 1rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
      width: fit-content;
    }

    .featured-title {
      font-family: "Manrope", sans-serif;
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 700;
      color: white;
      margin: 0 0 1rem 0;
      max-width: 30ch;
    }

    .featured-excerpt {
      font-family: "Inter", sans-serif;
      font-size: 1.125rem;
      color: var(--on-surface-variant);
      margin: 0 0 2rem 0;
      max-width: 40ch;
    }

    .featured-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: linear-gradient(135deg, #6dddff 0%, #00d2fd 100%);
      color: var(--surface-dim);
      padding: 1rem 2rem;
      border-radius: 999px;
      font-family: "Inter", sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s ease;
      width: fit-content;
    }

    .featured-btn:hover {
      box-shadow: 0 0 20px rgba(109, 221, 255, 0.4);
    }

    .featured-btn .material-symbols-outlined {
      transition: transform 0.3s ease;
    }

    .featured-btn:hover .material-symbols-outlined {
      transform: translateX(4px);
    }

    /* Latest */
    .journal-latest {
      margin-bottom: 8rem;
    }

    .latest-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 3rem;
    }

    .latest-title {
      font-family: "Manrope", sans-serif;
      font-size: 1.75rem;
      font-weight: 700;
      margin: 0;
      color: var(--on-surface);
    }

    .latest-link {
      font-family: "Inter", sans-serif;
      font-size: 0.875rem;
      color: var(--primary);
      text-decoration: none;
      border-bottom: 1px solid rgba(0, 210, 255, 0.2);
      padding-bottom: 0.25rem;
      transition: border-color 0.3s ease;
    }

    .latest-link:hover {
      border-color: var(--primary);
    }

    .latest-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    @media (min-width: 768px) {
      .latest-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .latest-card {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .latest-card-image {
      position: relative;
      aspect-ratio: 4/5;
      border-radius: 12px;
      overflow: hidden;
      background: var(--surface-container-low);
    }

    .latest-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.8;
      transition: transform 0.5s ease;
    }

    .latest-card:hover .latest-card-image img {
      transform: scale(1.1);
    }

    .latest-card-category {
      position: absolute;
      top: 1rem;
      left: 1rem;
      background: rgba(26, 30, 38, 0.8);
      backdrop-filter: blur(8px);
      color: var(--on-surface);
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      font-size: 0.625rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .latest-card-content {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .latest-card-title {
      font-family: "Manrope", sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      margin: 0;
      transition: color 0.3s ease;
    }

    .latest-card-title a {
      color: var(--on-surface);
      text-decoration: none;
    }

    .latest-card:hover .latest-card-title a {
      color: var(--primary);
    }

    .latest-card-excerpt {
      font-family: "Inter", sans-serif;
      font-size: 0.875rem;
      color: var(--on-surface-variant);
      margin: 0;
      line-height: 1.6;
    }

    /* Categories */
    .journal-categories {
      margin-bottom: 8rem;
    }

    .categories-title {
      font-family: "Manrope", sans-serif;
      font-size: 1.75rem;
      font-weight: 700;
      margin: 0 0 3rem 0;
      color: var(--on-surface);
    }

    .categories-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .category-btn {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      border: none;
      border-radius: 999px;
      padding: 1.25rem 2rem;
      cursor: pointer;
      transition: background 0.3s ease;
    }

    .category-btn:hover {
      background: var(--surface-bright);
    }

    .category-btn .material-symbols-outlined {
      color: var(--cat-color);
      transition: transform 0.3s ease;
    }

    .category-btn:hover .material-symbols-outlined {
      transform: rotate(12deg);
    }

    .category-btn span:last-child {
      font-family: "Inter", sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--on-surface);
    }

    /* Newsletter */
    .journal-newsletter {
      margin-bottom: 4rem;
    }

    .newsletter-card {
      position: relative;
      background: rgba(26, 25, 25, 0.7);
      backdrop-filter: blur(20px);
      border-radius: 12px;
      padding: 3rem;
      text-align: center;
      overflow: hidden;
    }

    @media (min-width: 768px) {
      .newsletter-card {
        padding: 5rem;
      }
    }

    .newsletter-blob-1 {
      position: absolute;
      top: -6rem;
      right: -6rem;
      width: 24rem;
      height: 24rem;
      background: rgba(191, 129, 255, 0.1);
      border-radius: 50%;
      filter: blur(100px);
    }

    .newsletter-blob-2 {
      position: absolute;
      bottom: -6rem;
      left: -6rem;
      width: 24rem;
      height: 24rem;
      background: rgba(0, 210, 255, 0.1);
      border-radius: 50%;
      filter: blur(100px);
    }

    .newsletter-content {
      position: relative;
      z-index: 10;
      max-width: 40ch;
      margin: 0 auto;
    }

    .newsletter-title {
      font-family: "Manrope", sans-serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      margin: 0 0 1.5rem 0;
      color: var(--on-surface);
    }

    .newsletter-desc {
      font-family: "Inter", sans-serif;
      font-size: 1rem;
      color: var(--on-surface-variant);
      margin: 0 0 2.5rem 0;
      line-height: 1.6;
    }

    .newsletter-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 32rem;
      margin: 0 auto;
    }

    @media (min-width: 768px) {
      .newsletter-form {
        flex-direction: row;
      }
    }

    .newsletter-input {
      flex: 1;
      background: var(--surface-container-high);
      border: none;
      border-radius: 999px;
      padding: 1rem 2rem;
      font-family: "Inter", sans-serif;
      font-size: 1rem;
      color: var(--on-surface);
      transition: box-shadow 0.3s ease;
    }

    .newsletter-input::placeholder {
      color: #525252;
    }

    .newsletter-input:focus {
      outline: none;
      box-shadow: 0 0 0 2px rgba(0, 210, 255, 0.4);
    }

    .newsletter-btn {
      background: linear-gradient(135deg, #6dddff 0%, #00d2fd 100%);
      border: none;
      border-radius: 999px;
      padding: 1rem 2.5rem;
      font-family: "Inter", sans-serif;
      font-size: 0.875rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--surface-dim);
      cursor: pointer;
      transition: transform 0.3s ease;
      white-space: nowrap;
    }

    .newsletter-btn:hover {
      transform: scale(1.05);
    }

    .newsletter-btn:active {
      transform: scale(0.98);
    }

    .newsletter-note {
      font-size: 0.625rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(248, 250, 252, 0.4);
      margin: 1.5rem 0 0 0;
    }
  </style>

  <script slot="scripts" is:inline src="/src/scripts/theme-init.js"></script>
  <script slot="scripts" src="/src/scripts/theme-toggle.ts"></script>
  <script slot="scripts" src="/src/scripts/main.ts"></script>
</Layout>
