---
import Layout from '@layouts/ProjectLayout.astro';
import BlogHeader from '@components/blog/BlogHeader.astro';
import BlogFooter from '@components/blog/BlogFooter.astro';
import type { MarkdownInstance } from 'astro';

interface BlogPost {
  title: string;
  author: string;
  date: string;
  categories: string[];
  description: string;
  image: string;
  readTime: string;
}

type BlogModule = MarkdownInstance<BlogPost>;

const modules = import.meta.glob('/src/data/blogs/*.md', { eager: true }) as Record<string, BlogModule>;
const posts = Object.entries(modules).map(([path, post]) => {
  const slug = path.split("/").pop()?.replace(".md", "") ?? "";
  return {
    slug,
    frontmatter: post.frontmatter,
  };
});
---

<Layout
  title="Blog · Posts"
  description="Listado de publicaciones"
>
  <BlogHeader />

  <main id="master" class="blog-layout">
    <article class="blog-content">
      <header class="blog-hero">
        <div class="blog-hero-content">
          <p class="blog-kicker">Archivo del Blog</p>
          <h1 class="blog-hero-title">Todas las publicaciones</h1>
          <p class="blog-hero-lead">
            Encuentra todas las entradas y recursos sobre IA, desarrollo y tecnología.
          </p>
        </div>
      </header>

      <section class="blog-recent">
        <div class="blog-grid">
          {posts.map((post: any) => (
            <article class="blog-card">
              <div class="blog-card-image">
                <img src={post.frontmatter.image ?? '/assets/images/astro-vim.webp'} alt={post.frontmatter.title} />
              </div>
              <div class="blog-card-content">
                <span class="blog-card-category">{post.frontmatter.categories?.[0]}</span>
                <h3 class="blog-card-title">
                  <a href={`/blog/posts/${post.slug}`}>{post.frontmatter.title}</a>
                </h3>
                <p class="blog-card-excerpt">{post.frontmatter.description}</p>
                <div class="blog-card-meta">
                  <span>{post.frontmatter.readTime}</span>
                  <span>{post.frontmatter.date}</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </article>
  </main>

  <BlogFooter />

  <style>
    .blog-layout {
      padding: 3rem 1.5rem 6rem;
      max-width: 1200px;
      margin: 0 auto;
      color: #f8fafc;
    }

    .blog-hero {
      text-align: left;
      padding: 4rem 3rem;
      background: #0f172a;
      border-radius: 24px;
      margin-bottom: 3rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .blog-kicker {
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-size: 0.75rem;
      color: #60a5fa;
      font-weight: 700;
      margin: 0 0 1rem 0;
    }

    .blog-hero-title {
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 900;
      margin: 0 0 1rem 0;
      color: #f8fafc;
    }

    .blog-hero-lead {
      font-size: 1.1rem;
      color: #cbd5e1;
      margin: 0;
    }

    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .blog-card {
      background: #0b1220;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .blog-card-image img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .blog-card-content {
      padding: 1.5rem;
    }

    .blog-card-category {
      color: #60a5fa;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 700;
    }

    .blog-card-title a {
      color: #f8fafc;
      text-decoration: none;
    }

    .blog-card-excerpt {
      color: #cbd5e1;
    }

    .blog-card-meta {
      display: flex;
      gap: 1rem;
      color: #94a3b8;
      font-size: 0.85rem;
    }
  </style>

  <script slot="scripts" is:inline src="/src/scripts/theme-init.js"></script>
  <script slot="scripts" src="/src/scripts/theme-toggle.ts"></script>
  <script slot="scripts" src="/src/scripts/main.ts"></script>
</Layout>
