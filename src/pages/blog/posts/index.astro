---
import Layout from '@layouts/ProjectLayout.astro';
import BlogHeader from '@components/blog/BlogHeader.astro';
import BlogFooter from '@components/blog/BlogFooter.astro';
import type { MarkdownInstance } from 'astro';

interface BlogPost {
  title: string;
  author: string;
  date: string;
  categories: string[];
  description: string;
  image: string;
  readTime: string;
}

type BlogModule = MarkdownInstance<BlogPost>;

const modules = import.meta.glob('/data/blogs/*.md', { eager: true }) as Record<string, BlogModule>;
const allPosts = Object.entries(modules).map(([path, post]) => {
  const slug = path.split("/").pop()?.replace(".md", "") ?? "";
  return {
    slug,
    frontmatter: post.frontmatter,
  };
}).sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const categories = [...new Set(allPosts.flatMap(post => post.frontmatter.categories || []))];

const POSTS_PER_PAGE = 5;
const currentPage = 1;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);

const categoryColors: Record<string, string> = {
  "IA News": "#3b82f6",
  "Google": "#a855f7", 
  "Multimodal": "#86fea7",
  "Strategy": "#bf81ff",
  "Visuals": "#00d2ff",
  "Code": "#86fea7",
  "Thoughts": "#f472b6"
};
---

<Layout
  title="Blog · Archive"
  description="Archivo de todas las publicaciones"
>
  <BlogHeader />

  <main class="archive-main">
    <div class="archive-bg-right"></div>
    <div class="archive-bg-left"></div>

    <header class="archive-header">
      <h1 class="archive-title">Archive</h1>
      
      <div class="archive-filters">
        <button class="filter-btn filter-btn--active" data-category="all">All</button>
        {categories.map((category) => (
          <button class="filter-btn" data-category={category}>{category}</button>
        ))}
      </div>
    </header>

    <section class="archive-list" id="posts-container">
      {posts.map((post) => (
        <article class="archive-entry" data-category={post.frontmatter.categories?.[0]}>
          <div class="editorial-grid">
            <div class="archive-entry-image">
              <img 
                src={post.frontmatter.image || '/assets/images/astro-vim.webp'} 
                alt={post.frontmatter.title}
              />
            </div>
            <div class="archive-entry-content">
              <h2 class="archive-entry-title">
                <a href={`/blog/posts/${post.slug}`}>{post.frontmatter.title}</a>
              </h2>
              <div class="archive-entry-meta">
                <span 
                  class="archive-entry-category"
                  style={`--category-color: ${categoryColors[post.frontmatter.categories?.[0]] || '#3b82f6'}`}
                >
                  {post.frontmatter.categories?.[0]}
                </span>
                <time datetime={post.frontmatter.date}>
                  {new Date(post.frontmatter.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
              <p class="archive-entry-excerpt">{post.frontmatter.description}</p>
            </div>
            <div class="archive-entry-arrow">
              <span class="material-symbols-outlined">arrow_forward</span>
            </div>
          </div>
        </article>
      ))}
    </section>

    <div class="archive-pagination">
      <button class="pagination-btn" disabled>
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <div class="pagination-numbers">
        <button class="pagination-number pagination-number--active">1</button>
        {Array.from({ length: totalPages - 1 }, (_, i) => (
          <button class="pagination-number">{i + 2}</button>
        ))}
      </div>
      <button class="pagination-btn" disabled={totalPages <= 1}>
        <span class="material-symbols-outlined">chevron_right</span>
      </button>
    </div>

    <footer class="archive-footer">
      <div class="archive-footer-brand">
        <span class="archive-footer-logo">The Nocturnal Gallery</span>
        <p class="archive-footer-copy">© 2024 The Nocturnal Gallery. All rights reserved.</p>
      </div>
      <div class="archive-footer-links">
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">RSS</a>
      </div>
    </footer>
  </main>

  <BlogFooter />

  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

  <style>
    :root {
      --primary: #3b82f6;
      --secondary: #a855f7;
      --tertiary: #86fea7;
      --background: #020617;
      --surface: #0f172a;
      --surface-container: #0c0e12;
      --surface-container-high: #1a1e26;
      --surface-container-low: #080a0f;
      --surface-dim: #05070a;
      --on-surface: #f8f9fe;
      --on-surface-variant: #adaaaa;
      --outline: #767575;
    }

    .material-symbols-outlined {
      font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
    }

    body {
      background-color: var(--surface-dim);
      color: var(--on-surface);
      font-family: "Inter", sans-serif;
    }

    .archive-main {
      padding: 8rem 1.5rem 4rem;
      max-width: 1400px;
      margin: 0 auto;
      position: relative;
      min-height: 100vh;
    }

    .archive-bg-right {
      position: fixed;
      top: 0;
      right: 0;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.05) 0%, transparent 70%);
      border-radius: 50%;
      filter: blur(120px);
      pointer-events: none;
      z-index: -1;
    }

    .archive-bg-left {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(168, 85, 247, 0.05) 0%, transparent 70%);
      border-radius: 50%;
      filter: blur(100px);
      pointer-events: none;
      z-index: -1;
    }

    .archive-header {
      margin-bottom: 5rem;
    }

    .archive-title {
      font-family: "Manrope", sans-serif;
      font-size: clamp(5rem, 10vw, 8rem);
      font-weight: 900;
      letter-spacing: -0.04em;
      line-height: 0.9;
      margin: 0 0 2rem 0;
      color: var(--on-surface);
    }

    .archive-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      padding: 2rem 0;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .filter-btn {
      font-family: "Manrope", sans-serif;
      padding: 0.75rem 1.5rem;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
      background: var(--surface-container);
      color: rgba(248, 250, 252, 0.6);
    }

    .filter-btn:hover {
      background: var(--surface-container-high);
      color: var(--on-surface);
    }

    .filter-btn--active {
      background: var(--primary);
      color: var(--surface-dim);
    }

    .filter-btn--active:hover {
      background: var(--primary);
    }

    .archive-list {
      display: flex;
      flex-direction: column;
    }

    .archive-entry {
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      transition: all 0.3s ease;
    }

    .archive-entry:hover {
      background: rgba(59, 130, 246, 0.03);
    }

    .archive-entry.hidden {
      display: none;
    }

    .editorial-grid {
      display: grid;
      grid-template-columns: 200px 1fr auto;
      gap: 3rem;
      align-items: center;
      padding: 3rem 0;
    }

    @media (max-width: 768px) {
      .editorial-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
    }

    .archive-entry-image {
      aspect-ratio: 4/3;
      overflow: hidden;
      border-radius: 4px;
      background: var(--surface-container-high);
      transition: all 0.5s ease;
    }

    .archive-entry-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.6;
      transition: opacity 0.3s ease;
      filter: grayscale(100%);
    }

    .archive-entry:hover .archive-entry-image img {
      opacity: 1;
      filter: grayscale(0%);
    }

    .archive-entry-content {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .archive-entry-title {
      font-family: "Manrope", sans-serif;
      font-size: clamp(1.5rem, 3vw, 2.25rem);
      font-weight: 600;
      margin: 0;
      transition: color 0.3s ease;
      color: var(--on-surface);
    }

    .archive-entry-title a {
      color: inherit;
      text-decoration: none;
    }

    .archive-entry:hover .archive-entry-title a {
      color: var(--primary);
    }

    .archive-entry-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .archive-entry-category {
      font-family: "Manrope", sans-serif;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--category-color, var(--primary));
    }

    .archive-entry-meta time {
      font-family: "Inter", sans-serif;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(248, 250, 252, 0.4);
    }

    .archive-entry-excerpt {
      font-family: "Inter", sans-serif;
      color: rgba(248, 250, 252, 0.6);
      font-size: 1rem;
      line-height: 1.6;
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
      max-width: 60ch;
    }

    .archive-entry-arrow {
      display: flex;
      justify-content: flex-end;
    }

    .archive-entry-arrow span {
      font-size: 1.5rem;
      color: rgba(248, 250, 252, 0.2);
      transition: all 0.3s ease;
    }

    .archive-entry:hover .archive-entry-arrow span {
      color: var(--primary);
      transform: translateX(8px);
    }

    @media (max-width: 768px) {
      .archive-entry-arrow {
        display: none;
      }
    }

    .archive-pagination {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      margin-top: 6rem;
    }

    .pagination-btn {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: transparent;
      color: rgba(248, 250, 252, 0.6);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
    }

    .pagination-btn:hover:not(:disabled) {
      border-color: var(--primary);
      color: var(--primary);
    }

    .pagination-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .pagination-numbers {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.5rem;
      background: var(--surface-container-low);
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .pagination-number {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: none;
      background: transparent;
      color: rgba(248, 250, 252, 0.4);
      font-family: "Manrope", sans-serif;
      font-size: 0.75rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .pagination-number:hover {
      color: var(--on-surface);
    }

    .pagination-number--active {
      background: var(--primary);
      color: var(--surface-dim);
    }

    .archive-footer {
      margin-top: auto;
      padding-top: 4rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    @media (max-width: 768px) {
      .archive-footer {
        flex-direction: column;
        gap: 2rem;
        text-align: center;
      }
    }

    .archive-footer-brand {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .archive-footer-logo {
      font-family: "Manrope", sans-serif;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--on-surface);
    }

    .archive-footer-copy {
      font-size: 0.65rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: rgba(248, 250, 252, 0.3);
      margin: 0;
    }

    .archive-footer-links {
      display: flex;
      gap: 2rem;
    }

    .archive-footer-links a {
      font-size: 0.65rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: rgba(248, 250, 252, 0.3);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .archive-footer-links a:hover {
      color: var(--primary);
    }
  </style>

  <script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('filter-btn--active'));
        btn.classList.add('filter-btn--active');

        document.querySelectorAll('.archive-entry').forEach(entry => {
          const entryCategory = entry.getAttribute('data-category');
          if (category === 'all' || entryCategory === category) {
            entry.classList.remove('hidden');
          } else {
            entry.classList.add('hidden');
          }
        });
      });
    });
  </script>

  <script slot="scripts" is:inline src="/src/scripts/theme-init.js"></script>
  <script slot="scripts" src="/src/scripts/theme-toggle.ts"></script>
  <script slot="scripts" src="/src/scripts/main.ts"></script>
</Layout>
