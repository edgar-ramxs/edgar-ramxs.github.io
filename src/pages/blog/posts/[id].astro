---
import Layout from "@layouts/ProjectLayout.astro";
import BlogHeader from "@components/blog/BlogHeader.astro";
import BlogFooter from "@components/blog/BlogFooter.astro";
import type { MarkdownInstance } from 'astro';

const base = "/blog";

interface BlogPost {
  title: string;
  author: string;
  date: string;
  categories: string[];
  description: string;
  image: string;
  readTime: string;
}

type BlogModule = MarkdownInstance<BlogPost>;

export async function getStaticPaths() {
  const modules = import.meta.glob('/data/blogs/*.md', { eager: true }) as Record<string, BlogModule>;
  const posts = Object.entries(modules).map(([path, post]) => {
    const slug = path.split("/").pop()?.replace(".md", "") ?? "";
    return {
      slug,
      frontmatter: post.frontmatter,
      Content: post.Content,
    };
  });
  
  return posts.map((post) => ({ params: { id: post.slug }, props: { post } }));
}

const { post } = Astro.props;
---

<Layout
  title={post.frontmatter.title}
  description={post.frontmatter.description}
>
  <BlogHeader />
  
  <main id="master" class="blog-layout">
    <aside class="blog-aside" aria-label="Anuncios izquierda">
      <div class="ad-slot">Espacio para anuncios</div>
      <div class="ad-slot">Espacio para anuncios</div>
    </aside>

    <article class="blog-content">
      <header class="blog-post-header">
        <div class="blog-meta">
          <span class="blog-category">{post.frontmatter.categories?.[0]}</span>
          <span class="blog-date">{post.frontmatter.date}</span>
          <span class="blog-read-time">{post.frontmatter.readTime} lectura</span>
        </div>
        <h1 class="blog-post-title">{post.frontmatter.title}</h1>
        <p class="blog-post-lead">{post.frontmatter.description}</p>
        <div class="blog-tags">
          {post.frontmatter.categories?.map((tag: string) => (
            <span class="blog-tag">#{tag}</span>
          ))}
        </div>
      </header>

      <figure class="blog-figure">
        <img src={post.frontmatter.image} alt={post.frontmatter.title} />
        <figcaption>Vista previa del artículo.</figcaption>
      </figure>

      <article class="blog-markdown">
        <post.Content />
      </article>

      <footer class="blog-footer">
        <a href={`${base}/`} class="blog-link">← Volver al blog</a>
      </footer>
    </article>

    <aside class="blog-aside" aria-label="Anuncios derecha">
      <div class="ad-slot">Espacio para anuncios</div>
      <div class="ad-slot">Espacio para anuncios</div>
    </aside>
  </main>

  <BlogFooter />

  <style>
    .blog-layout {
      padding: 4rem 1.5rem 8rem;
      max-width: 1300px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(220px, 1fr) minmax(0, 3.5fr) minmax(220px, 1fr);
      gap: 4rem;
      align-items: start;
      background-color: #020617;
      color: #f8fafc;
    }

    .blog-post-header {
      text-align: left;
      padding: 4rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .blog-post-title {
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 950;
      letter-spacing: -0.04em;
      line-height: 1;
      margin: 1.5rem 0;
      color: #ffffff;
      text-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .blog-post-lead {
      font-size: 1.4rem;
      line-height: 1.5;
      max-width: 60ch;
      margin: 0 0 2.5rem 0;
      color: #94a3b8;
      font-weight: 400;
    }

    .blog-meta {
      color: #e2e8f0;
    }

    .blog-section h2 {
      font-size: 2.25rem;
      font-weight: 900;
      color: #f8fafc;
      margin: 4rem 0 1.5rem;
      letter-spacing: -0.02em;
    }

    .blog-section p {
      font-size: 1.2rem;
      line-height: 1.8;
      color: #cbd5e1;
      margin-bottom: 2rem;
    }

    .blog-markdown h2 {
      font-size: 2.25rem;
      font-weight: 900;
      color: #f8fafc;
      margin: 3rem 0 1.5rem;
    }

    .blog-markdown h3 {
      font-size: 1.5rem;
      font-weight: 800;
      color: #e2e8f0;
      margin: 2rem 0 1rem;
    }

    .blog-markdown p,
    .blog-markdown li {
      font-size: 1.1rem;
      line-height: 1.8;
      color: #cbd5e1;
    }

    .blog-markdown ul {
      padding-left: 1.2rem;
      display: grid;
      gap: 0.5rem;
    }

    .blog-markdown blockquote {
      margin: 2rem 0;
      padding: 1.5rem;
      border-left: 4px solid #60a5fa;
      background: rgba(30, 41, 59, 0.8);
      border-radius: 12px;
      color: #e2e8f0;
    }

    .blog-markdown a {
      color: #60a5fa;
      text-decoration: underline;
    }

    .blog-section li {
      color: #e2e8f0;
    }

    .blog-figure img {
      border-radius: 32px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.5);
    }

    .blog-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .blog-tag {
      background: rgba(148, 163, 184, 0.15);
      border-radius: 999px;
      padding: 0.2rem 0.7rem;
      font-size: 0.8rem;
      color: #f8fafc;
      border: 1px solid rgba(148, 163, 184, 0.2);
    }

    .blog-section p,
    .blog-section li {
      line-height: 1.6;
    }

    .blog-figure {
      margin: 0;
      display: grid;
      gap: 0.75rem;
    }

    .blog-figure img {
      width: 100%;
      border-radius: 14px;
    }

    blockquote {
      margin: 0;
      padding: 1.5rem;
      border-left: 4px solid #94a3b8;
      background: rgba(148, 163, 184, 0.1);
      border-radius: 12px;
      color: #e2e8f0;
    }

    blockquote cite {
      display: block;
      margin-top: 0.75rem;
      font-style: normal;
      opacity: 0.75;
    }

    .blog-media {
      position: relative;
      width: 100%;
      padding-bottom: 56.25%;
      border-radius: 16px;
      overflow: hidden;
      background: #0f172a;
    }

    .blog-aside {
      color: #e2e8f0;
    }

    .ad-slot {
      border: 1px dashed rgba(148, 163, 184, 0.4);
      background: rgba(15, 23, 42, 0.8);
      color: #e2e8f0;
    }

    .blog-media iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .blog-footer {
      margin-top: 1rem;
    }

    .blog-link {
      text-decoration: none;
      font-weight: 600;
    }

    .blog-aside {
      position: sticky;
      top: 6rem;
      display: grid;
      gap: 1rem;
    }

    .ad-slot {
      min-height: 140px;
      border: 1px dashed rgba(148, 163, 184, 0.4);
      border-radius: 12px;
      display: grid;
      place-items: center;
      font-size: 0.85rem;
      opacity: 0.7;
    }

    @media (max-width: 1024px) {
      .blog-layout {
        grid-template-columns: 1fr;
      }

      .blog-aside {
        position: static;
        order: 2;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }
    }
  </style>

  <script slot="scripts" is:inline src="/src/scripts/theme-init.js"></script>
  <script slot="scripts" src="/src/scripts/theme-toggle.ts"></script>
  <script slot="scripts" src="/src/scripts/main.ts"></script>
</Layout>
