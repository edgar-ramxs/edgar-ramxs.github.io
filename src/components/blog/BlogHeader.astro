---
const navItems = [
  { label: "Portfolio", href: "/portfolio/" },
  { label: "Journal", href: "/blog/" },
  { label: "Archive", href: "/blog/posts", active: true },
  { label: "Contact", href: "/portfolio/contact" },
];
---

<nav class="blog-nav">
  <div class="blog-nav-inner">
    <a href="/" class="blog-brand">
      THE NOCTURNAL GALLERY
    </a>
    
    <div class="blog-nav-links">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class:list={["blog-nav-link", { "blog-nav-link--active": item.active }]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="blog-nav-actions">
      <button class="blog-nav-icon" aria-label="Grid view">
        <span class="material-symbols-outlined">grid_view</span>
      </button>
      <button class="blog-nav-btn">
        Inquire
      </button>
    </div>
  </div>
  <div class="blog-nav-line"></div>
</nav>

<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

<style>
  .blog-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: 64px;
    background: rgba(12, 14, 18, 0.7);
    backdrop-filter: blur(24px);
  }

  :global(.dark) .blog-nav {
    background: rgba(5, 7, 10, 0.7);
  }

  .blog-nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
    padding: 0 2rem;
    max-width: 1600px;
    margin: 0 auto;
  }

  .blog-brand {
    font-family: "Manrope", sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #f8f9fe;
    text-decoration: none;
  }

  .blog-nav-links {
    display: flex;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .blog-nav-links {
      display: none;
    }
  }

  .blog-nav-link {
    font-family: "Manrope", sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0;
    color: rgba(248, 250, 252, 0.6);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 0.5rem 0;
    position: relative;
  }

  .blog-nav-link:hover {
    color: #f8f9fe;
    transform: scale(0.98);
  }

  .blog-nav-link--active {
    color: #00d2ff;
    font-weight: 700;
    border-bottom: 2px solid #00d2ff;
    padding-bottom: 0.25rem;
  }

  .blog-nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .blog-nav-icon {
    background: none;
    border: none;
    color: rgba(248, 250, 252, 0.6);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .blog-nav-icon:hover {
    color: #00d2ff;
  }

  .blog-nav-icon .material-symbols-outlined {
    font-size: 1.5rem;
  }

  .blog-nav-btn {
    font-family: "Manrope", sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #00d2ff;
    color: #05070a;
    border: none;
    border-radius: 999px;
    padding: 0.5rem 1.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .blog-nav-btn:hover {
    transform: scale(0.98);
  }

  .blog-nav-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 210, 255, 0.2), transparent);
  }
</style>
