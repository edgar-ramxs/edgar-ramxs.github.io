---
const currentYear = new Date().getFullYear();
---

<footer class="blog-footer">
  <div class="footer-glow-top"></div>
  <div class="blog-footer-inner">
    <div class="blog-footer-brand">
      <span class="blog-footer-logo">THE CURATED KINETIC.</span>
      <p class="blog-footer-copy">© {currentYear} THE CURATED KINETIC. ALL RIGHTS RESERVED.</p>
    </div>
    <div class="blog-footer-links">
      <a href="#">Privacy</a>
      <a href="#">Terms</a>
      <a href="#">RSS</a>
      <a href="#">Colophon</a>
    </div>
  </div>
</footer>

<style>
  .blog-footer {
    position: relative;
    width: 100%;
    background: #0e0e0e;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 5rem 3rem 3rem;
    margin-top: auto;
  }

  .footer-glow-top {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(109, 221, 255, 0.3), transparent);
  }

  .blog-footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .blog-footer-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .blog-footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .blog-footer-brand {
      align-items: flex-start;
    }
  }

  .blog-footer-logo {
    font-family: "Manrope", sans-serif;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #ffffff;
    font-size: 1.25rem;
  }

  .blog-footer-copy {
    font-family: "Manrope", sans-serif;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #525252;
    margin: 0;
  }

  .blog-footer-links {
    display: flex;
    gap: 3rem;
  }

  .blog-footer-links a {
    font-family: "Manrope", sans-serif;
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #525252;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .blog-footer-links a:hover {
    color: #6dddff;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
