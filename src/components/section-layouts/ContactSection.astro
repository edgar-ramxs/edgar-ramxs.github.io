---
import { profileData } from "@cv";
import SocialLink from "@components/composite/SocialLink.astro";

interface Props {
  id?: string;
  title?: string;
  titleItalic?: string;
  label?: string;
  showTitle?: boolean;
  showEmail?: boolean;
  showSocial?: boolean;
}

const {
  id = "contacto",
  title = "¿Tienes un proyecto",
  titleItalic = "en mente?",
  label = "Hablemos",
  showTitle = true,
  showEmail = true,
  showSocial = true,
} = Astro.props;
---

<section class="section" id={id}>
  <div class="container">
    <p class="section-label">{label}</p>

    <div class="contact-inner">
      <div class="contact-text">
        {
          showTitle && (
            <h2 class="section-title">
              {title}
              <br />
              <em>{titleItalic}</em>
            </h2>
          )
        }
        <slot name="description">
          <p>{profileData.description}</p>
        </slot>

        {
          showEmail && (
            <a href={`mailto:${profileData.email}`} class="email-link">
              {profileData.email}
              <svg width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
                <path d="M224.49,40.49a12,12,0,0,1,17,17L130.83,168H208a12,12,0,0,1,0,24H48a12,12,0,0,1,0-24H125.17L42.49,57.49A12,12,0,0,1,57.49,42.49l96,96a12,12,0,0,1,0,17l-96,96a12,12,0,1,1-17-17L130.83,184H48a12,12,0,0,1,0-24H208a12,12,0,0,1,0,24H125.17L57.49,99.51a12,12,0,1,1,17-17l96-96A12,12,0,0,1,224.49,40.49Z" />
              </svg>
            </a>
          )
        }
      </div>

      {
        showSocial && (
          <div class="contact-links">
            {profileData.profiles.map((social) => (
              <SocialLink
                label={social.network}
                url={social.url}
                icon={social.icon}
                variant="button"
              />
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: end;
    padding: 4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .contact-text :global(p) {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 440px;
  }

  .contact-text :global(em) {
    font-style: italic;
    color: var(--accent);
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .email-link:hover {
    gap: 0.9rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }

  @media (max-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr;
      padding: 2rem;
      gap: 2.5rem;
    }

    .contact-links {
      flex-direction: row;
      align-items: flex-start;
    }
  }
</style>
