---
export interface Props {
  idAnalytics: string;
  domain?: string;
}

const { idAnalytics, domain = "https://www.googletagmanager.com" } = Astro.props;
---

<!-- Google Analytics -->
<script type="text/partytown" async src={`${domain}/gtag/js?id=${idAnalytics}`}></script>
<script type="text/partytown" define:vars={{ idAnalytics }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("js", new Date());
  gtag("config", idAnalytics);
</script>
<!-- End Google Analytics -->
