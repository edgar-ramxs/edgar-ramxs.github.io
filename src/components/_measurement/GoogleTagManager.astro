---
export interface Props {
  idTagManager: string;
  domain?: string;
  container?: string;
}

const {
  idTagManager,
  domain = "https://www.googletagmanager.com",
  container = "gtm.js",
} = Astro.props;
---

<!-- Google Tag Manager -->
<script type="text/partytown" define:vars={{ idTagManager, domain, container }}>
  (function (w, d, s, l, i) {
    w[l] = w[l] || [];
    w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
    var f = d.getElementsByTagName(s)[0],
      j = d.createElement(s),
      dl = l != "dataLayer" ? "&l=" + l : "";
    j.async = true;
    j.src = domain + "/" + container + "?id=" + i + dl;
    f.parentNode.insertBefore(j, f);
  })(window, document, "script", "dataLayer", idTagManager);
</script>
<!-- End Google Tag Manager -->
