---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container">
    <span class="footer-name">Edgar Ramos</span>
    <span class="footer-copy">© {year} — Analista de Datos</span>
    <a href="#inicio" class="footer-top">
      Volver arriba
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path d="M12 19V5M5 12l7-7 7 7"></path>
      </svg>
    </a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-name {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--text);
  }

  .footer-copy {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .footer-top {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .footer-top:hover {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
