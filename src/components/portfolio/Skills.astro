---
import { skillsData } from "@cv";
import { Icon } from "astro-icon/components";

const softSkills = skillsData.filter((s) => s.type === "soft");

const technicalGroups = [
  {
    category: "Languages",
    items: skillsData.filter((s) => s.type === "technical" && s.keywords?.includes("Languages")),
  },
  {
    category: "Frontend",
    items: skillsData.filter((s) => s.type === "technical" && s.keywords?.includes("Frontend")),
  },
  {
    category: "Backend",
    items: skillsData.filter((s) => s.type === "technical" && s.keywords?.includes("Backend")),
  },
  {
    category: "Databases",
    items: skillsData.filter((s) => s.type === "technical" && s.keywords?.includes("Databases")),
  },
  {
    category: "Data Science",
    items: skillsData.filter((s) => s.type === "technical" && s.keywords?.includes("Data Science")),
  },
  {
    category: "DevOps / Cloud",
    items: skillsData.filter(
      (s) =>
        s.type === "technical" &&
        (s.keywords?.includes("DevOps") ||
          s.keywords?.includes("Cloud") ||
          s.keywords?.includes("Infrastructure"))
    ),
  },
  {
    category: "Security",
    items: skillsData.filter((s) => s.type === "technical" && s.keywords?.includes("Security")),
  },
  {
    category: "Tools",
    items: skillsData.filter((s) => s.type === "technical" && s.keywords?.includes("Tools")),
  },
];
---

<section class="section" id="skills">
  <div class="container">
    <p class="section-label">Capacidades</p>
    <h2 class="section-title">Habilidades blandas</h2>

    <div class="soft-skills-grid">
      {
        softSkills.map((skill) => (
          <div class="soft-skill-card">
            <Icon name={skill.icon} class="soft-skill-icon" />
            <span class="soft-skill-name">{skill.name}</span>
          </div>
        ))
      }
    </div>

    <h2 class="section-title">Stack técnico</h2>

    <div class="skills-grid">
      {
        technicalGroups.map((group) => (
          <div class="skill-group">
            <h3 class="skill-category">{group.category}</h3>
            <ul class="skill-list">
              {group.items.map((item) => (
                <li class="skill-item">
                  <Icon name={item.icon} class="skill-icon" />
                  {item.name}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .soft-skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .soft-skill-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: all 0.2s;
  }

  .soft-skill-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .soft-skill-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--accent);
  }

  .soft-skill-name {
    font-family: var(--mono);
    font-size: 0.68rem;
    text-align: center;
    color: var(--text);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }

  .skill-group {
    padding: 2.5rem 2rem;
    border-right: 1px solid var(--border);
    transition: background 0.2s;
  }

  .skill-group:last-child {
    border-right: none;
  }

  .skill-group:hover {
    background: var(--surface);
  }

  .skill-category {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--text);
  }

  .skill-icon {
    width: 1.1rem;
    height: 1.1rem;
    color: var(--accent);
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .skill-group:nth-child(2) {
      border-right: none;
    }

    .skill-group:nth-child(1),
    .skill-group:nth-child(2) {
      border-bottom: 1px solid var(--border);
    }
  }

  @media (max-width: 500px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }

    .skill-group {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }

    .skill-group:last-child {
      border-bottom: none;
    }
  }
</style>
