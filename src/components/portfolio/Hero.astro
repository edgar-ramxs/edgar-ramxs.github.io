---
import { profileData } from "@cv";
import CodeSnippet from "./CodeSnippet.astro";

const { hero } = profileData;

const nameParts = profileData.name.split(" ");
const name = nameParts[0];
const nameItalic = nameParts.length > 1 ? nameParts.slice(1).join(" ") : "";
const role = profileData.occupation;
const company = profileData.company;
const companyUrl = profileData.companyUrl;
const lema = hero?.lema || "";
const eyebrow = "Disponible para proyectos";
const showAvailability = true;
---

<section class="hero" id="inicio">
  <div class="hero-inner container">
    <div class="hero-content-centered">
      {
        showAvailability && (
          <p class="hero-eyebrow fade-up delay-1">
            <span class="dot" /> {eyebrow}
          </p>
        )
      }
      <h1 class="hero-name fade-up delay-2">
        {name}
        <span class="name-italic">{nameItalic}</span>
      </h1>
      <p class="hero-role fade-up delay-3">{role}</p>
      {
        company && (
          <p class="hero-company fade-up delay-3">
            {companyUrl ? (
              <a href={companyUrl} target="_blank" rel="noopener">
                en {company}
              </a>
            ) : (
              <>en {company}</>
            )}
          </p>
        )
      }
      {lema && <p class="hero-desc fade-up delay-4">{lema}</p>}
      <div class="hero-cta fade-up delay-5">
        <a href="/projects" class="btn-primary">Ver proyectos</a>
        <a href="/contact" class="btn-ghost">Contacto</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 64px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: -20%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--accent-soft) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .hero-content-centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 700px;
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px #22c55e;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  .hero-name {
    font-family: var(--serif);
    font-size: clamp(3.5rem, 8vw, 6.5rem);
    font-weight: 400;
    line-height: 1;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .name-italic {
    font-style: italic;
    color: var(--accent);
  }

  .hero-role {
    font-family: var(--mono);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .hero-company {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .hero-company a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-company a:hover {
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 440px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
    padding: 0.75rem 1.75rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: #a83a22;
    transform: translateY(-1px);
  }

  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.75rem 1.75rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: all 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .hero-content-centered {
      padding: 0 1rem;
    }
  }
</style>
