---
import { worksData, getSkillById } from "@cv";
import { Icon } from "astro-icon/components";
---

<section class="section" id="experiencia">
  <div class="container">
    <p class="section-label">Employment</p>
    <h2 class="section-title">Última Experiencia</h2>

    <div class="timeline">
      {
        worksData.slice(0, 1).map((job, i) => (
          <div class="timeline-item">
            <div class="timeline-left">
              <span class="period">
                {job.startDate} — {job.endDate || "Presente"}
              </span>
            </div>
            <div class="timeline-dot-wrapper">
              <Icon name={job.icon} class="timeline-role-icon" />
            </div>
            <div class="timeline-right">
              <h3 class="job-role">
                <a href={`/experiences/${job.id}`} class="hover:underline">
                  {job.position}
                </a>
              </h3>
              <p class="job-company">
                <a href={job.url} target="_blank" rel="noopener noreferrer">
                  {job.name}
                </a>
                <span class="location">
                  · {job.location} ({job.location_type})
                </span>
              </p>
              <p class="job-desc">{job.summary}</p>
              <ul class="job-responsibilities">
                {job.responsibilities.map((resp) => (
                  <li>{resp}</li>
                ))}
              </ul>
              <div class="job-tags">
                {job.skills.map((skillId) => {
                  const skill = getSkillById(skillId);
                  return (
                    <span class="tag">
                      {skill?.icon && <Icon name={skill.icon} class="tag-icon" />}
                      {skill?.name || skillId}
                    </span>
                  );
                })}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 200px auto 1fr;
    gap: 0 2.5rem;
    padding-bottom: 3.5rem;
    position: relative;
  }

  .timeline-left {
    text-align: right;
    padding-top: 0.15rem;
  }

  .period {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .timeline-dot-wrapper {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: var(--bg);
    border: 1px solid var(--border);
    position: relative;
    left: -14px;
    top: 0.15rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.3s ease;
  }

  .timeline-item:hover .timeline-dot-wrapper {
    background: var(--accent);
    border-color: var(--accent);
    transform: scale(1.1);
  }

  .timeline-role-icon {
    width: 14px;
    height: 14px;
    color: var(--accent);
    transition: color 0.3s ease;
  }

  .timeline-item:hover .timeline-role-icon {
    color: white;
  }

  .timeline-right {
    padding-top: 0;
  }

  .job-role {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .job-company {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.9rem;
  }

  .job-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
    max-width: 540px;
  }

  .job-responsibilities {
    margin-bottom: 1.5rem;
  }

  .job-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    border-radius: 2px;
    color: var(--text-muted);
  }

  .tag-icon {
    width: 0.85rem;
    height: 0.85rem;
  }

  @media (max-width: 768px) {
    .timeline-item {
      grid-template-columns: auto 1fr;
      gap: 0 1.5rem;
    }
    .timeline-left {
      display: none;
    }
    .timeline-dot-wrapper {
      left: -14px;
    }
    .period {
      display: block;
      font-size: 0.65rem;
      margin-bottom: 0.5rem;
    }
  }
</style>
