---
import { Icon } from "astro-icon/components";
import { profileData } from "@cv";
import StatCard from "@components/composite/StatCard.astro";

const { hero } = profileData;
const { importantStats } = hero || {};

const id = "sobre-mi";
const label = "Sobre mí";
const title = "Datos que";
const titleItalic = "cuentan historias";
const showTitle = true;
const showGitHubLink = true;
const githubUrl = profileData.profiles.find((p) => p.network === "GitHub")?.url;
const githubUsername = "github.com/edgar-ramxs";

const paragraphs = hero?.heroDescription || [
  "Soy Edgar Ramos, analista de datos con enfoque en transformar conjuntos de datos complejos en insights accionables. Me apasiona el proceso completo: desde la limpieza y exploración de datos hasta la comunicación de resultados de forma clara y visual.",
  "Trabajo con Python y SQL como herramientas principales, y uso Power BI y Tableau para construir dashboards que cualquier equipo pueda interpretar. También disfruto optimizar mi entorno de trabajo — desde configs de terminal hasta entornos Linux personalizados.",
  "Actualmente abierto a nuevos proyectos y oportunidades.",
];
---

<section class="section" id={id}>
  <div class="container">
    <p class="section-label">{label}</p>

    <div class="about-grid">
      <div class="about-text">
        {
          showTitle && (
            <h2 class="section-title">
              {title}
              <br />
              <em>{titleItalic}</em>
            </h2>
          )
        }
        {paragraphs.map((p) => <p>{p}</p>)}

        {
          showGitHubLink && githubUrl && (
            <div class="about-links">
              <a href={githubUrl} target="_blank" rel="noopener" class="about-link">
                <Icon name="mdi:github" class="about-icon" />
                {githubUsername}
              </a>
            </div>
          )
        }
      </div>

      <div class="about-stats">
        {
          importantStats?.map((stat) => (
            <StatCard
              number={stat.number}
              label={stat.label}
              icon={stat.icon}
              variant={stat.variant || "default"}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  em {
    font-style: italic;
    color: var(--accent);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 5rem;
    align-items: start;
  }

  .about-text p {
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-size: 1rem;
    line-height: 1.85;
    text-align: justify;
  }

  .about-links {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .about-icon {
    width: 1rem;
    height: 1rem;
  }

  .about-link:hover {
    color: var(--accent);
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding-top: 5rem;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .stat-icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--accent);
  }

  .stat-card.accent {
    background: var(--accent);
    border-color: var(--accent);
  }

  .stat-card.accent .stat-icon,
  .stat-card.accent .stat-number,
  .stat-card.accent .stat-label {
    color: white;
  }

  .stat-number {
    font-family: var(--serif);
    font-size: 1.8rem;
    color: var(--text);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-stats {
      padding-top: 0;
    }
  }
</style>
