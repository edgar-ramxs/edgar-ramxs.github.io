---
import { Icon } from "astro-icon/components";
import { profileData } from "@cv";
const profile = profileData;
---

<section class="section" id="contacto">
  <div class="container">
    <p class="section-label">Hablemos</p>

    <div class="contact-inner">
      <div class="contact-text">
        <h2 class="section-title">¿Tienes un proyecto<br /><em>en mente?</em></h2>
        <p>
          {profile.description}
        </p>

        <a href={`mailto:${profile.email}`} class="email-link">
          {profile.email}
          <Icon name="ph:arrow-up-right" />
        </a>
      </div>

      <div class="contact-links">
        {
          profile.profiles.map((social) => (
            <a href={social.url} target="_blank" rel="noopener" class="contact-social">
              <Icon name={social.icon} class="social-icon" />
              <span class="social-label">{social.network}</span>
              <Icon name="ph:arrow-up-right" class="arrow-icon" />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  em {
    font-style: italic;
    color: var(--accent);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: end;
    padding: 4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .contact-text p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 440px;
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .email-link svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .email-link:hover {
    gap: 0.9rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }

  .contact-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: all 0.2s ease;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg);
  }

  .contact-social:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateX(-5px);
  }

  .social-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .arrow-icon {
    width: 0.9rem;
    height: 0.9rem;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .contact-social:hover .arrow-icon {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr;
      padding: 2rem;
      gap: 2.5rem;
    }

    .contact-links {
      flex-direction: row;
      align-items: flex-start;
    }
  }
</style>
