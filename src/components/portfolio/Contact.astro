---
import { Icon } from "astro-icon/components";
import { profileData } from "@cv";
import SocialLink from "@components/composite/SocialLink.astro";

interface Props {
  id?: string;
  title?: string;
  titleItalic?: string;
  label?: string;
  showTitle?: boolean;
  description?: string;
  showEmail?: boolean;
  showSocial?: boolean;
}

const {
  id = "contacto",
  title = "¿Tienes un proyecto",
  titleItalic = "en mente?",
  label = "Hablemos",
  showTitle = true,
  description = profileData.importantSkills || profileData.description,
  showEmail = true,
  showSocial = true,
} = Astro.props;
---

<section class="section" id={id}>
  <div class="container">
    <p class="section-label">{label}</p>

    <div class="contact-inner">
      <div class="contact-text">
        {
          showTitle && (
            <h2 class="section-title">
              {title}
              <br />
              <em>{titleItalic}</em>
            </h2>
          )
        }
        <p>{description}</p>

        {
          showEmail && (
            <a href={`mailto:${profileData.email}`} class="email-link">
              {profileData.email}
              <Icon name="ph:arrow-up-right" />
            </a>
          )
        }
      </div>

      {
        showSocial && (
          <div class="contact-links">
            {profileData.profiles.map((social) => (
              <SocialLink
                label={social.network}
                url={social.url}
                icon={social.icon}
                variant="button"
              />
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  em {
    font-style: italic;
    color: var(--accent);
  }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: end;
    padding: 4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .contact-text p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
    max-width: 440px;
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .email-link svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .email-link:hover {
    gap: 0.9rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }

  .contact-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: all 0.2s ease;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg);
  }

  .contact-social:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateX(-5px);
  }

  .social-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .arrow-icon {
    width: 0.9rem;
    height: 0.9rem;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .contact-social:hover .arrow-icon {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr;
      padding: 2rem;
      gap: 2.5rem;
    }

    .contact-links {
      flex-direction: row;
      align-items: flex-start;
    }
  }
</style>
