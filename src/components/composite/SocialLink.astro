---
import { Icon } from "astro-icon/components";

interface Props {
  label: string;
  url: string;
  icon?: string;
  showArrow?: boolean;
  variant?: "default" | "button";
  class?: string;
}

const {
  label,
  url,
  icon,
  showArrow = true,
  variant = "default",
  class: className = "",
} = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener"
  class:list={["social-link", `social-${variant}`, className]}
>
  {icon && <Icon name={icon} class="social-icon" />}
  <span class="social-label">{label}</span>
  {showArrow && <Icon name="ph:arrow-up-right" class="arrow-icon" />}
</a>

<style>
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .social-icon {
    width: 1rem;
    height: 1rem;
  }

  .arrow-icon {
    width: 0.9rem;
    height: 0.9rem;
    opacity: 0.5;
    transition: all 0.2s ease;
  }

  .social-link:hover {
    color: var(--accent);
  }

  .social-link:hover .arrow-icon {
    opacity: 1;
  }

  .social-button {
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--bg);
  }

  .social-button:hover {
    border-color: var(--accent);
    transform: translateX(-5px);
  }
</style>
