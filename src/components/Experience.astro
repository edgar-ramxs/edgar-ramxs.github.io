---
const jobs = [
  {
    period: '2023 — Presente',
    role: 'Analista de Datos',
    company: 'Empresa actual',
    description:
      'Análisis exploratorio de datos, construcción de dashboards en Power BI y automatización de reportes con Python. Trabajo directo con equipos de negocio para traducir requerimientos en soluciones de datos.',
    tags: ['Python', 'Power BI', 'SQL', 'Excel'],
  },
  {
    period: '2022 — 2023',
    role: 'Asistente de Datos',
    company: 'Empresa anterior',
    description:
      'Soporte en limpieza y validación de bases de datos. Generación de reportes periódicos y mantenimiento de pipelines de datos básicos.',
    tags: ['Excel', 'SQL', 'Python'],
  },
];
---

<section class="section" id="experiencia">
  <div class="container">
    <p class="section-label">Historial de trabajo</p>
    <h2 class="section-title">Experiencia</h2>

    <div class="timeline">
      {jobs.map((job, i) => (
        <div class="timeline-item">
          <div class="timeline-left">
            <span class="period">{job.period}</span>
          </div>
          <div class="timeline-dot"></div>
          <div class="timeline-right">
            <h3 class="job-role">{job.role}</h3>
            <p class="job-company">{job.company}</p>
            <p class="job-desc">{job.description}</p>
            <div class="job-tags">
              {job.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.timeline {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 200px;
  top: 0;
  bottom: 0;
  width: 1px;
  background: var(--border);
}

.timeline-item {
  display: grid;
  grid-template-columns: 200px 1px 1fr;
  gap: 0 2.5rem;
  padding-bottom: 3.5rem;
  position: relative;
}

.timeline-left {
  text-align: right;
  padding-top: 0.15rem;
}

.period {
  font-family: var(--mono);
  font-size: 0.7rem;
  letter-spacing: 0.05em;
  color: var(--text-muted);
}

.timeline-dot {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg);
  position: relative;
  left: -4px;
  top: 0.35rem;
  flex-shrink: 0;
}

.timeline-right {
  padding-top: 0;
}

.job-role {
  font-family: var(--serif);
  font-size: 1.3rem;
  font-weight: 400;
  color: var(--text);
  margin-bottom: 0.2rem;
}

.job-company {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.9rem;
}

.job-desc {
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.8;
  margin-bottom: 1rem;
  max-width: 540px;
}

.job-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.tag {
  font-family: var(--mono);
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 0.25rem 0.65rem;
  border-radius: 2px;
  color: var(--text-muted);
}

@media (max-width: 768px) {
  .timeline::before { left: 0; }
  .timeline-item {
    grid-template-columns: 1px 1fr;
    gap: 0 1.5rem;
  }
  .timeline-left { display: none; }
  .timeline-dot { left: -4px; }
  .period { display: block; font-size: 0.65rem; margin-bottom: 0.5rem; }
}
</style>
