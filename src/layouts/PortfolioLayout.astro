---
import "@styles/portfolio.css";

import Navbar from "@components/portfolio/Navbar.astro";
import Footer from "@components/portfolio/Footer.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "product";
  noindex?: boolean;
  locale?: string;
  siteName?: string;
  keywords?: string[];
  themeColor?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Portfolio",
  description = "Descripción optimizada para SEO de máximo 160 caracteres que describe claramente el contenido.",
  canonical = "https://edgar-ramxs.github.io",
  image,
  imageAlt = "Vista principal de Mi Sitio",
  type = "website",
  noindex,
  locale = "es_CL",
  siteName,
  keywords = ["keyword1", "keyword2", "keyword3"],
  themeColor = "#0f172a",
  schema,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={image}
  imageAlt={imageAlt}
  type={type}
  noindex={noindex}
  locale={locale}
  siteName={siteName}
  keywords={keywords}
  themeColor={themeColor}
  schema={schema}
>
  <!-- Container -->
  <header slot="navbar">
    <Navbar />
  </header>

  <main slot="container">
    <slot />
  </main>

  <!-- Footer Layout -->
  <Footer slot="footer" />

  <!-- Scripts Import -->
  <script slot="scripts" is:inline src="/src/scripts/theme-init.js"></script>
  <script slot="scripts" src="/src/scripts/theme-toggle.ts"></script>
  <script slot="scripts" src="/src/scripts/main.ts"></script>
  <script slot="scripts" src="/src/scripts/search.ts"></script>
  <script slot="scripts" src="/src/scripts/background-art.ts"></script>
  <script slot="scripts" src="/src/scripts/route-animations.ts"></script>
  <!-- End Scripts Import -->
</BaseLayout>
