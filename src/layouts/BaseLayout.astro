---
import TagmanagerNoscript from "@components/_measurement/GoogleTagmanagerNoscript.astro";
import Head from "@components/_global/HeadBase.astro";

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "product";
  noindex?: boolean;
  locale?: string;
  siteName?: string;
  keywords?: string[];
  themeColor?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  image,
  imageAlt,
  type,
  noindex,
  locale,
  siteName,
  keywords,
  themeColor,
  schema,
} = Astro.props;

const adId = "PUBLIC_GOOGLE_ADSENSE_ID";
const gtmId = "PUBLIC_GTM_ID";
const gaId = "PUBLIC_GA_ID";
const googleVerification = "PUBLIC_GOOGLE_VERIFICATION";
---

<!doctype html>
<html lang="es" class="dark">
  <!-- HEAD -->
  <head>
    <Head
      slot="head"
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      imageAlt={imageAlt}
      type={type}
      noindex={noindex}
      locale={locale}
      siteName={siteName}
      keywords={keywords}
      themeColor={themeColor}
      schema={schema}
      adId={adId}
      gtmId={gtmId}
      gaId={gaId}
      googleVerification={googleVerification}
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>

  <!-- BODY -->
  <body class="bg-surface font-body overflow-x-hidden">
    <!-- TAG MANAGER BOY -->
    {gtmId && <TagmanagerNoscript idTagManager={gtmId} />}

    <!-- HEADER -->
    <slot name="navbar" />

    <!-- MAIN - CONTAINER -->
    <slot name="container"/>

    <!-- FOOTER -->
    <slot name="footer"/>

    <!-- SCRIPTS -->
    <slot name="scripts" />
  </body>
</html>
