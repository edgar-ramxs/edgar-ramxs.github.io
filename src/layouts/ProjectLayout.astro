---
import '@styles/portfolio.css';
import BaseLayout from '@layouts/BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  siteName?: string;
  locale?: string;
  themeColor?: string;
  keywords?: string[];
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "product";
  noindex?: boolean;
}

const {
  title,
  description = 'Vista previa del proyecto',
  canonical = Astro.url.href,
  siteName = 'Mi Sitio',
  locale = 'es_CL',
  themeColor = '#0f172a',
  keywords,
  image,
  imageAlt,
  type,
  noindex,
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "url": canonical,
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  siteName={siteName}
  locale={locale}
  themeColor={themeColor}
  keywords={keywords}
  image={image}
  imageAlt={imageAlt}
  type={type}
  noindex={noindex}
  schema={schema}
>
  <main slot="container">
    <slot />
  </main>

  <slot slot="scripts" name="scripts" />
</BaseLayout>
