{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@data/*": ["src/data/*"],
      "@components/*": ["src/components/*"],
      "@measurement/*": ["src/components/_measurement/*"],
      "@images/*": ["src/images/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pages/*": ["src/pages/*"],
      "@scripts/*": ["src/scripts/*"],
      "@styles/*": ["src/styles/*"],
      "@types": ["src/types/types.d.ts"],
      "@cv": ["src/types/cv.ts"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*", "src/types/**/*.d.ts", "src/types/**/*.ts"],
  "exclude": ["dist"]
}